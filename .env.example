DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_SECRET_KEY=replace-with-generated-secret

# Production only:
# DJANGO_DEBUG=false
# DJANGO_ALLOWED_HOSTS=yourdomain.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com
# DJANGO_SECURE_SSL_REDIRECT=true
DATABASE_URL=postgres://postgres:replace-me@db:5432/construction_reports
POSTGRES_USER=postgres
# Avoid # @ : % in password (or URL-encode in DATABASE_URL if set explicitly)
POSTGRES_PASSWORD=replace-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Podman/container stack (infra/podman-compose.yml)
APP_IMAGE=ghcr.io/rupret007/constructiondaily:feature-latest
APP_PORT=8000
# Optional: override for deploy/poll scripts
# DEPLOY_PATH=/opt/constructiondaily
# COMPOSE_FILE=/opt/constructiondaily/infra/podman-compose.yml

VITE_API_BASE=/api
